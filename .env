# PostgreSQL credentials (shared across all instances)
POSTGRES_USER=statesync
POSTGRES_PASSWORD=statesync_secret

# JWT configuration
JWT_SECRET=change-this-secret-in-production
JWT_ALGORITHM=HS256

# Redis
REDIS_URL=redis://redis:6379/0

# Ministry service URLs (internal Docker network)
MINISTRY_CIVIL_URL=http://ministry-civil:8001
MINISTRY_EDUCATION_URL=http://ministry-education:8002
MINISTRY_DEFENSE_URL=http://ministry-defense:8003
